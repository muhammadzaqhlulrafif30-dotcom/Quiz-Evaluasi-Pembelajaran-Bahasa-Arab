  <script>
    const TOTAL_QUESTIONS = 5;
    let currentQuestion = 0;
    let score = 0;
    let participantName = '';
    let selectedAnswers = Array(TOTAL_QUESTIONS).fill(null);
    let currentRecords = [];
    let dataReady = false;

    const screens = {
      start: document.getElementById('start-screen'),
      quiz: document.getElementById('quiz-screen'),
      result: document.getElementById('result-screen'),
      scores: document.getElementById('scores-screen')
    };

    const questionPanels = [...document.querySelectorAll('.question-panel')];
    const nextButton = document.getElementById('next-button');
    const helper = document.getElementById('quiz-helper');
    const questionCount = document.getElementById('question-count');
    const progressFill = document.getElementById('progress-fill');
    const startForm = document.getElementById('start-form');
    const nameInput = document.getElementById('participant-name');
    const startError = document.getElementById('start-error');
    const scoreNumber = document.getElementById('score-number');
    const resultName = document.getElementById('result-name');
    const saveStatus = document.getElementById('save-status');
    const scoresList = document.getElementById('scores-list');
    const emptyScores = document.getElementById('empty-scores');

    function showScreen(name) {
      Object.values(screens).forEach(screen => screen.classList.remove('active'));
      screens[name].classList.add('active');
    }

    function updateQuestionUI() {
      questionPanels.forEach((panel, index) => {
        panel.classList.toggle('hidden', index !== currentQuestion);
      });
      questionCount.textContent = `${currentQuestion + 1} / ${TOTAL_QUESTIONS}`;
      progressFill.style.width = `${((currentQuestion + 1) / TOTAL_QUESTIONS) * 100}%`;

      nextButton.disabled = selectedAnswers[currentQuestion] === null;
      nextButton.classList.toggle('cursor-not-allowed', nextButton.disabled);
      nextButton.classList.toggle('bg-[#b8c4b9]', nextButton.disabled);
      nextButton.classList.toggle('bg-[#24483f]', !nextButton.disabled);
    }

    questionPanels.forEach((panel, qIndex) => {
      const options = [...panel.querySelectorAll('.option-btn')];
      options.forEach((option, optionIndex) => {
        option.addEventListener('click', () => {
          options.forEach(btn => btn.classList.remove('is-selected'));
          option.classList.add('is-selected');
          selectedAnswers[qIndex] = optionIndex;
          updateQuestionUI();
        });
      });
    });

    startForm.addEventListener('submit', (event) => {
      event.preventDefault();
      const value = nameInput.value.trim();
      if (!value) {
        startError.textContent = 'Silakan isi nama peserta terlebih dahulu.';
        startError.classList.remove('hidden');
        return;
      }
      participantName = value;
      startError.classList.add('hidden');
      showScreen('quiz');
      updateQuestionUI();
    });

    nextButton.addEventListener('click', () => {
      if (selectedAnswers[currentQuestion] === null) return;

      const currentPanel = questionPanels[currentQuestion];
      const correctAnswer = Number(currentPanel.dataset.answer);
      if (selectedAnswers[currentQuestion] === correctAnswer) {
        score++;
      }

      if (currentQuestion < TOTAL_QUESTIONS - 1) {
        currentQuestion++;
        updateQuestionUI();
      } else {
        completeQuiz();
      }
    });

    async function completeQuiz() {
      scoreNumber.textContent = score;
      resultName.textContent = participantName;
      saveStatus.textContent = 'Menyimpan hasil...';
      showScreen('result');

      if (!dataReady) {
        saveStatus.textContent = 'Hasil belum dapat disimpan. Silakan coba beberapa saat lagi.';
        return;
      }

      if (currentRecords.length >= 999) {
        saveStatus.textContent = 'Batas maksimal data peserta telah tercapai.';
        return;
      }

      const result = await window.dataSdk.create({
        nama_peserta: participantName,
        skor: score,
        total_soal: TOTAL_QUESTIONS,
        tanggal: new Date().toISOString()
      });

      if (result.isOk) {
        saveStatus.textContent = 'Hasil berhasil disimpan.';
      } else {
        saveStatus.textContent = 'Hasil belum berhasil disimpan. Silakan coba lagi nanti.';
      }
    }

    function resetQuiz() {
      currentQuestion = 0;
      score = 0;
      selectedAnswers = Array(TOTAL_QUESTIONS).fill(null);
      questionPanels.forEach(panel => {
        panel.querySelectorAll('.option-btn').forEach(btn => btn.classList.remove('is-selected'));
      });
      nameInput.value = '';
      showScreen('start');
      updateQuestionUI();
    }

    document.getElementById('retry-button').addEventListener('click', resetQuiz);
    document.getElementById('view-results-button').addEventListener('click', () => showScreen('scores'));
    document.getElementById('back-home-button').addEventListener('click', resetQuiz);

    function formatDate(iso) {
      const date = new Date(iso);
      return new Intl.DateTimeFormat('id-ID', {
        day: '2-digit',
        month: 'short',
        year: 'numeric'
      }).format(date);
    }

    function renderScores(records) {
      const sorted = [...records].sort((a, b) => new Date(b.tanggal) - new Date(a.tanggal));
      const existing = new Map([...scoresList.children].map(el => [el.dataset.id, el]));

      sorted.forEach(record => {
        let row = existing.get(record.__backendId);
        if (!row) {
          const fragment = document.getElementById('score-row-template').content.cloneNode(true);
